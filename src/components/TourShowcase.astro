---
import type { Tour } from "../types/tour";

const locationLabels: Record<Tour["location"], string> = {
  lisbon: "Lissabon",
  sintra: "Sintra",
};

interface TourShowcaseProps {
  tours: Tour[];
}

const { tours } = Astro.props as TourShowcaseProps;

const resolvedTours = tours.map((tour) => ({
  ...tour,
  images: tour.images.map((image) => image + "/m/600x0"),
}));
---

<section id="tours" class="relative border-t border-bone/10 py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.4em] text-bone/40">Wandel keuzes</p>
        <h2 class="mt-6 font-display text-3xl text-bone md:text-4xl">
          Ervaar de sfeer van Lissabon en Sintra te voet
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-bone/60">
          Onze selectie van Nederlandstalige wandelingen is met zorg samengesteld voor kleine
          gezelschappen, waarbij we eeuwenoude straatjes combineren met culinaire lekkernijen
          en een prachtige natuur.
        </p>
      </div>
    </div>

    <!-- Tour cards grid -->
    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        resolvedTours.map((tour, index) => (
          <article
            class="group relative isolate aspect-[3/4] cursor-pointer overflow-hidden rounded-3xl border border-bone/[.08] transition-[border-color,box-shadow,transform] duration-300 hover:-translate-y-1 hover:border-accent/35 hover:shadow-glow max-sm:aspect-[4/5] will-change-transform"
            data-tour-card
          >
            {/* Image link — covers entire card at z-1; content at z-2 with pointer-events:none
                so clicks fall through to here by default */}
            <a
              href={`/tours/${tour.slug}`}
              class="absolute inset-0 z-[1] block overflow-hidden rounded-3xl"
              tabindex="-1"
              aria-label={`Bekijk foto's en details van ${tour.name}`}
              data-ph-event="tour_card_open"
              data-ph-tour={tour.name}
              data-ph-location={locationLabels[tour.location]}
              data-ph-source="card"
            >
              {tour.images.map((img, imgIndex) => (
                <img
                  src={img}
                  alt={
                    imgIndex === 0
                      ? `${tour.name} — ${locationLabels[tour.location]}`
                      : ""
                  }
                  loading={index < 3 ? "eager" : "lazy"}
                  decoding="async"
                  class:list={[
                    "absolute inset-0 h-full w-full object-cover transition-opacity duration-700",
                    imgIndex === 0 ? "opacity-100" : "opacity-0",
                  ]}
                  data-image-index={imgIndex}
                />
              ))}

              {/* Gradient overlay */}
              <div class="tour-gradient absolute inset-0 z-[1] bg-[linear-gradient(to_top,rgba(4,4,4,0.92)_0%,rgba(4,4,4,0.7)_30%,rgba(4,4,4,0.15)_55%,transparent_75%)]" />
            </a>

            {/* Content overlay — pointer-events:none; interactive children opt back in */}
            <div class="pointer-events-none relative z-[2] flex h-full flex-col justify-between p-6">
              {/* Top: location badge */}
              <div>
                <span class="inline-flex items-center rounded-full border border-white/15 bg-black/50 px-3.5 py-1.5 text-[0.625rem] font-medium uppercase tracking-[0.35em] text-bone/70 backdrop-blur-md">
                  {locationLabels[tour.location]}
                </span>
              </div>

              {/* Bottom: title, description, dots, footer */}
              <div class="flex flex-col gap-3">
                <h3 class="font-display text-[1.625rem] leading-[1.15] text-bone transition-colors duration-300 group-hover:text-champagne lg:text-[1.875rem]">
                  {tour.name}
                </h3>

                {/* Description + expand toggle */}
                <div class="flex flex-col gap-1.5" data-desc-wrap>
                  <p
                    class="line-clamp-2 text-[0.8125rem] leading-relaxed text-bone/50 transition-colors duration-300 group-hover:text-bone/65"
                    data-desc
                  >
                    {tour.description}
                  </p>
                  <button
                    class="pointer-events-auto self-start text-[0.6875rem] font-medium uppercase tracking-[0.1em] text-accent/75 transition-colors duration-200 hover:text-accent"
                    data-expand-btn
                    aria-expanded="false"
                    type="button"
                  >
                    Lees meer
                  </button>
                </div>

                {/* Image cycling dots */}
                <div
                  class="pointer-events-none flex items-center justify-center gap-1.5 transition-opacity duration-300 sm:opacity-0 sm:group-hover:opacity-100"
                  aria-hidden="true"
                  data-dots
                >
                  {tour.images.map((_, imgIndex) => (
                    <span
                      class:list={[
                        "h-1.5 rounded-full transition-all duration-300",
                        imgIndex === 0 ? "w-4 bg-accent" : "w-1.5 bg-bone/25",
                      ]}
                    />
                  ))}
                </div>

                {/* Footer: price + CTAs */}
                <div class="flex items-center justify-between gap-4 border-t border-bone/[.08] pt-3">
                  <span class="flex-shrink-0 whitespace-pre-line text-[0.9375rem] font-semibold leading-[1.4] text-bone">
                    {tour.price}
                  </span>
                  <div class="pointer-events-auto flex flex-shrink-0 items-center gap-3">
                    <a
                      href={`/tours/${tour.slug}`}
                      class="hidden whitespace-nowrap rounded-full border border-bone/[.12] px-3.5 py-2 text-[0.6875rem] font-medium uppercase tracking-[0.2em] text-bone/55 transition duration-300 hover:border-bone/30 hover:bg-bone/[.06] hover:text-bone sm:inline-flex"
                      data-ph-event="tour_detail_click"
                      data-ph-tour={tour.name}
                      data-ph-location={locationLabels[tour.location]}
                      data-ph-source="link"
                    >
                      Bekijk details
                    </a>
                    <a
                      href={`/?tour=${encodeURIComponent(tour.name)}#contact`}
                      class="whitespace-nowrap rounded-full bg-accent px-3.5 py-2 text-[0.6875rem] font-medium uppercase tracking-[0.2em] text-midnight transition duration-300 hover:bg-champagne"
                      data-tour-link
                      data-tour={tour.name}
                      data-ph-event="tour_book_click"
                      data-ph-tour={tour.name}
                      data-ph-location={locationLabels[tour.location]}
                      data-ph-availability={tour.toBook ? "bookable" : "inquire"}
                      data-ph-source="showcase"
                    >
                      {tour.toBook ? "Boek nu" : "Informeer"}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Only what Tailwind cannot express ─────────────── */

  /* Override line-clamp when description is expanded */
  [data-desc].is-expanded {
    display: block;
    overflow: visible;
    -webkit-line-clamp: unset;
  }

  /* Darken gradient when card is in reading mode */
  [data-tour-card].is-reading .tour-gradient {
    background: linear-gradient(
      to top,
      rgba(4, 4, 4, 0.98) 0%,
      rgba(4, 4, 4, 0.93) 40%,
      rgba(4, 4, 4, 0.75) 70%,
      rgba(4, 4, 4, 0.4) 100%
    );
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  // ── Image hover cycling ──────────────────────────────

  if (!prefersReducedMotion) {
    document
      .querySelectorAll<HTMLElement>("[data-tour-card]")
      .forEach((card) => {
        const images =
          card.querySelectorAll<HTMLImageElement>("[data-image-index]");
        const dots = card.querySelectorAll<HTMLElement>("[data-dots] span");
        if (images.length <= 1) return;

        let currentIndex = 0;
        let intervalId: ReturnType<typeof setInterval> | null = null;

        const showImage = (index: number) => {
          images.forEach((img, i) => {
            img.classList.toggle("opacity-100", i === index);
            img.classList.toggle("opacity-0", i !== index);
          });
          dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add("w-4", "bg-accent");
              dot.classList.remove("w-1.5", "bg-bone/25");
            } else {
              dot.classList.remove("w-4", "bg-accent");
              dot.classList.add("w-1.5", "bg-bone/25");
            }
          });
          currentIndex = index;
        };

        const startCycling = () => {
          if (intervalId) return;
          intervalId = setInterval(() => {
            showImage((currentIndex + 1) % images.length);
          }, 2400);
        };

        const stopCycling = () => {
          if (intervalId) {
            clearInterval(intervalId);
            intervalId = null;
          }
          showImage(0);
        };

        card.addEventListener("mouseenter", startCycling);
        card.addEventListener("mouseleave", stopCycling);
        card.addEventListener("focusin", startCycling);
        card.addEventListener("focusout", (e) => {
          if (!card.contains((e as FocusEvent).relatedTarget as Node)) {
            stopCycling();
          }
        });
      });
  }

  // ── Touch swipe to cycle images (mobile) ─────────────

  document
    .querySelectorAll<HTMLElement>("[data-tour-card]")
    .forEach((card) => {
      const images =
        card.querySelectorAll<HTMLImageElement>("[data-image-index]");
      const dots = card.querySelectorAll<HTMLElement>("[data-dots] span");
      if (images.length <= 1) return;

      let currentIndex = 0;

      const showImageTouch = (index: number) => {
        images.forEach((img, i) => {
          img.classList.toggle("opacity-100", i === index);
          img.classList.toggle("opacity-0", i !== index);
        });
        dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add("w-4", "bg-accent");
            dot.classList.remove("w-1.5", "bg-bone/25");
          } else {
            dot.classList.remove("w-4", "bg-accent");
            dot.classList.add("w-1.5", "bg-bone/25");
          }
        });
        currentIndex = index;
      };

      let touchStartX = 0;
      let touchStartY = 0;

      card.addEventListener("touchstart", (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      card.addEventListener("touchend", (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;

        // Only treat as swipe if horizontal movement > 40px and more horizontal than vertical
        if (Math.abs(dx) < 40 || Math.abs(dy) > Math.abs(dx)) return;

        e.preventDefault(); // prevent tap-to-navigate after a swipe

        const next =
          dx < 0
            ? (currentIndex + 1) % images.length
            : (currentIndex - 1 + images.length) % images.length;
        showImageTouch(next);
      });
    });

  // ── Description expand/collapse ──────────────────────

  document.querySelectorAll<HTMLElement>("[data-tour-card]").forEach((card) => {
    const desc = card.querySelector<HTMLElement>("[data-desc]");
    const btn = card.querySelector<HTMLButtonElement>("[data-expand-btn]");
    if (!desc || !btn) return;

    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      const expanded = btn.getAttribute("aria-expanded") === "true";
      if (expanded) {
        desc.classList.remove("is-expanded");
        btn.setAttribute("aria-expanded", "false");
        btn.textContent = "Lees meer";
        card.classList.remove("is-reading");
      } else {
        desc.classList.add("is-expanded");
        btn.setAttribute("aria-expanded", "true");
        btn.textContent = "Lees minder";
        card.classList.add("is-reading");
      }
    });
  });

  // ── Tour link scroll behavior ────────────────────────

  document.querySelectorAll("[data-tour-link]").forEach((link) => {
    link.addEventListener("click", (event) => {
      if (event.defaultPrevented) return;

      const isModifiedClick =
        (event as MouseEvent).button !== 0 ||
        (event as KeyboardEvent).metaKey ||
        (event as KeyboardEvent).ctrlKey ||
        (event as KeyboardEvent).shiftKey ||
        (event as KeyboardEvent).altKey;

      if (isModifiedClick) return;

      const contactSection = document.getElementById("contact");
      if (!contactSection) return;

      event.preventDefault();

      const tourName = (link as HTMLElement).getAttribute("data-tour");
      const tourSelect = document.getElementById(
        "tour",
      ) as HTMLSelectElement | null;
      if (tourName && tourSelect && "value" in tourSelect) {
        tourSelect.value = tourName;
      }

      if (tourName) {
        const url = new URL(window.location.href);
        url.searchParams.set("tour", tourName);
        url.hash = "contact";
        history.replaceState(null, "", url);
      }

      contactSection.scrollIntoView({
        behavior: prefersReducedMotion ? "auto" : "smooth",
      });
    });
  });
</script>
